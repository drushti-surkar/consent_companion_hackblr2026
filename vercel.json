{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "frontend/vapi.bundle.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/vapi.bundle.js",
      "dest": "/frontend/vapi.bundle.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  }
}
