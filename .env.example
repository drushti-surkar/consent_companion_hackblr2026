# OpenAI
OPENAI_API_KEY=sk-...

# Qdrant Cloud (from cloud.qdrant.io)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Vapi (from dashboard.vapi.ai)
VAPI_API_KEY=your-vapi-api-key

# Collection name in Qdrant
QDRANT_COLLECTION=consent_clauses

# Public URL of this backend (needed for Vapi webhook config)
# e.g. https://your-app.railway.app  OR  https://abc123.ngrok.io
PUBLIC_URL=https://your-public-url

# Vapi phone number (shown in UI + QR code) — copy from Vapi dashboard after creating assistant
VAPI_PHONE_NUMBER=+1XXXXXXXXXX
